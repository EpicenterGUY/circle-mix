{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://circle-mix.invalid/schemas/cmix-chart-v1.schema.json",
  "title": "CIRCLE MIX chart v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "formatVersion", "id", "notes"],
  "properties": {
    "format": {"const": "circle-mix-chart"},
    "formatVersion": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 64},
    "bpm": {"type": "number", "minimum": 20, "maximum": 1000},
    "offset": {"type": "number", "minimum": -60, "maximum": 60},
    "notes": {"type": "array", "minItems": 1, "maxItems": 100000, "items": {"$ref": "#/$defs/note"}},
    "extensions": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z0-9][a-z0-9.-]{1,62}$"},
      "additionalProperties": true
    }
  },
  "$defs": {
    "angle": {"type": "number", "minimum": 0, "exclusiveMaximum": 360},
    "positiveDuration": {"type": "number", "exclusiveMinimum": 0},
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "beat", "angle"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
        "type": {"enum": ["cut", "fx", "slideCW", "slideCCW", "trace", "traceCW", "traceCCW", "swingCW", "swingCCW", "scratchCW", "scratchCCW"]},
        "beat": {"type": "number", "minimum": 0},
        "angle": {"$ref": "#/$defs/angle"},
        "endAngle": {"$ref": "#/$defs/angle"},
        "durationBeat": {"$ref": "#/$defs/positiveDuration"},
        "signedSweepAngle": {"type": "number"},
        "direction": {"enum": ["CW", "CCW"]}
      },
      "allOf": [
        {
          "if": {"properties": {"type": {"enum": ["fx", "slideCW", "slideCCW", "trace", "traceCW", "traceCCW", "scratchCW", "scratchCCW"]}}, "required": ["type"]},
          "then": {"required": ["durationBeat"]}
        },
        {
          "if": {"properties": {"type": {"enum": ["slideCW", "slideCCW", "trace", "traceCW", "traceCCW"]}}, "required": ["type"]},
          "then": {"required": ["endAngle"]}
        },
        {
          "if": {"properties": {"type": {"enum": ["trace", "traceCW", "traceCCW"]}}, "required": ["type"]},
          "then": {
            "required": ["signedSweepAngle"],
            "properties": {"signedSweepAngle": {"anyOf": [{"type": "number", "exclusiveMinimum": 0}, {"type": "number", "exclusiveMaximum": 0}]}}
          }
        },
        {
          "if": {"properties": {"type": {"not": {"enum": ["trace", "traceCW", "traceCCW"]}}}, "required": ["type"]},
          "then": {"not": {"required": ["signedSweepAngle"]}}
        }
      ]
    }
  }
}
